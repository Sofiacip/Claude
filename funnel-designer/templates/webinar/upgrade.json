{
  "page_type": "upgrade_page",
  "funnel": "webinar",
  "sticky_cta": true,
  "nav": false,
  "sections": [
    {
      "id": "S1",
      "name": "Progress Bar",
      "component": "progress_bar",
      "slots": [],
      "steps": ["Registered", "Upgrade", "Enjoy"],
      "active_step": 1,
      "completed_steps": [0],
      "mobile": "full width, 3-step horizontal bar",
      "design_rules": ["Registered step is checked/completed", "Upgrade step is active/highlighted", "creates commitment bias"]
    },
    {
      "id": "S2",
      "name": "Congratulations Hook",
      "component": "text_block",
      "slots": ["host_name"],
      "mobile": "centered, celebratory tone",
      "design_rules": ["acknowledges registration", "builds momentum toward upgrade"]
    },
    {
      "id": "S3",
      "name": "Offer Headline",
      "component": "headline",
      "slots": ["oto1_headline"],
      "mobile": "full width, bold"
    },
    {
      "id": "S4",
      "name": "Urgency Warning",
      "component": "urgency_banner",
      "slots": [],
      "mobile": "full width, high-contrast, warning icon",
      "design_rules": ["⚠️ warning icon", "'DO NOT CLOSE — this offer expires' messaging", "high-contrast warning color against background"]
    },
    {
      "id": "S5",
      "name": "Discount Framing",
      "component": "discount_badge",
      "slots": ["oto1_regular_price", "oto1_price"],
      "mobile": "centered badge or callout",
      "design_rules": ["show percentage off prominently, e.g. '95% OFF — Today Only'"]
    },
    {
      "id": "S6",
      "name": "Bullet Benefits",
      "component": "bullet_list",
      "slots": ["oto1_benefits"],
      "mobile": "full width, checkmark icons",
      "design_rules": ["3-5 benefits of upgrading", "use checkmark or arrow icons"]
    },
    {
      "id": "S7",
      "name": "Countdown Timer",
      "component": "countdown_timer",
      "slots": [],
      "format": "minutes / seconds",
      "mobile": "2-column grid (minutes + seconds only)",
      "design_rules": ["minutes + seconds ONLY — no days or hours", "creates maximum urgency"]
    },
    {
      "id": "S8",
      "name": "Primary CTA",
      "component": "cta_button",
      "slots": ["oto1_price", "oto1_checkout_url"],
      "mobile": "full width button with price displayed",
      "design_rules": ["buy button shows the sale price", "struck-through original price next to bold sale price"]
    },
    {
      "id": "S9",
      "name": "Decline Link",
      "component": "decline_link",
      "slots": ["thankyou_url"],
      "mobile": "centered text link below CTA",
      "design_rules": ["loss framing: 'No thanks, I don't want to [benefit]'", "links to thank_you page", "smaller, muted text — not a button"]
    },
    {
      "id": "S10",
      "name": "Product Details",
      "component": "product_details",
      "slots": ["oto1_items"],
      "mobile": "full width, descriptive list of what they're getting"
    },
    {
      "id": "S11",
      "name": "Value Stack",
      "component": "value_stack",
      "slots": ["oto1_items", "oto1_regular_price"],
      "mobile": "full width rows with struck-through individual prices",
      "design_rules": ["each item shows name + individual value", "total value shown with struck-through price", "sale price highlighted"]
    },
    {
      "id": "S12",
      "name": "Repeat CTA",
      "component": "cta_with_decline",
      "slots": ["oto1_price", "oto1_checkout_url", "thankyou_url"],
      "mobile": "full width button + decline link repeated",
      "design_rules": ["same CTA button + decline link as S8/S9", "reinforces the offer one last time"]
    }
  ]
}
