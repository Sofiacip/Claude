# ============================================
# Impact OS Agent — Environment Configuration
# ============================================

# ClickUp API Token (generate at: ClickUp > Settings > Apps > API Token)
CLICKUP_API_TOKEN=your_token_here

# ClickUp List ID for "For Impact OS" in Prioritisation space
CLICKUP_LIST_ID=901521692113

# ClickUp Workspace ID
CLICKUP_WORKSPACE_ID=9015743183

# Path to your Impact OS codebase (where Claude Code will work)
PROJECT_PATH=/path/to/impact-os

# Path to your vision document (persistent context for the agent)
VISION_DOC_PATH=./VISION.md

# Agent behavior
POLL_INTERVAL_SECONDS=60
MAX_RETRIES=2
AUTO_COMMIT=false
LOG_LEVEL=info

# Optional: Slack webhook for notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx
