# Web Designer — Environment Variables
# Copy to .env and adjust as needed. All values below are the defaults.

# Server port for serve.mjs
PORT=3000

# Password for UI authentication (default: impact2024)
APP_PASSWORD=impact2024

# Maximum request body size in bytes (default: 100 MB)
MAX_BODY_SIZE=104857600

# Screenshot viewport dimensions (screenshot.mjs)
VIEWPORT_WIDTH=1440
VIEWPORT_HEIGHT=900

# Page load timeout in milliseconds (screenshot.mjs)
PAGE_LOAD_TIMEOUT=30000
